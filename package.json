{
  "name": "pos-fast-food",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@11.4.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "clean": "rm -rf dist .turbo coverage",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "tsc -b --pretty false",
    "test": "npm run build && tsc -b tests --force --pretty false && node dist/tests/run-tests.js",
    "format": "prettier --write \"**/*.{ts,tsx,js,cjs,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,cjs,json,md,yml,yaml}\"",
    "check": "npm run lint && npm run typecheck && npm run test && npm run verify:no-tracked-build-output",
    "verify:no-tracked-build-output": "node scripts/verify-no-tracked-build-output.cjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.5.3",
    "turbo": "^2.5.3",
    "typescript": "^5.8.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
